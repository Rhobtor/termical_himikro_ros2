ROS_DOMAIN_ID=30
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

L4T_VERSION=l4t-r35.3.1
L4T_MAJOR=35
L4T_MINOR=3
JETSON_ROS_BASE_IMAGE=dustynv/ros:humble-ros-base-l4t-r35.3.1
FANET_BASE_IMAGE=dustynv/ros:humble-pytorch-l4t-r35.3.1

ZED_SDK_MAJOR=4
ZED_SDK_MINOR=1
ZED_SDK_PATCH=4
ZED_IMAGE=zed_wrapper_2:latest
ZED_BUILD=0
ZED_CAMERA_MODEL=zed2i
ZED_CAMERA_NAME=zed
ZED_NODE_NAME=zed_node
ZED_RGB_TOPIC=/zed/zed_node/left/image_rect_color
ZED_DEPTH_TOPIC=/zed/zed_node/depth/depth_registered
ZED_DEPTH_CAMERA_INFO_TOPIC=/zed/zed_node/depth/camera_info

HIKMICRO_IMAGE=hikmicro_thermal_ros2:jetson
HIKMICRO_BUILD=0
HIKMICRO_RTSP_URL=rtsp://USER:PASSWORD@CAMERA_IP:554/Streaming/Channels/101
HIKMICRO_TRANSPORT=tcp
HIKMICRO_WIDTH=640
HIKMICRO_HEIGHT=512
HIKMICRO_FPS=25.0

FANET_IMAGE=cpgfanet_ros2_jetson:humble
FANET_BUILD=0
FANET_PARAMS_FILE=/workspace/deploy/fanet_fast.params.yaml
FANET_RAW_RGB_TOPIC=/fanet/raw/rgb
FANET_RAW_THERMAL_TOPIC=/fanet/raw/thermal
FANET_RGB_TOPIC=/fanet/input/rgb
FANET_THERMAL_TOPIC=/fanet/input/thermal
FANET_OVERLAY_TOPIC=/fanet/segmentation/overlay
FANET_PERSON_CENTROID_TOPIC=/fanet/person_centroid
FANET_PERSON_CENTROIDS_TOPIC=/fanet/person_centroids
FANET_PERSON_COUNT_TOPIC=/fanet/person_count
FANET_PERSON_POSITION_CAMERA_TOPIC=/fanet/person_position_camera
FANET_PERSON_POSITION_ROBOT_TOPIC=/fanet/person_position_robot
FANET_PERSON_DISTANCE_TOPIC=/fanet/person_distance
FANET_OUTPUT_DIR=/absolute/path/to/CPGFANet/ros2_outputs
FANET_SYNC_RATE=15.0